{
  "name": "jokko-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter @jokko/web dev",
    "dev:mobile": "pnpm --filter @jokko/mobile start",
    "build:web": "pnpm --filter @jokko/web build",
    "lint": "pnpm --filter @jokko/web lint",
    "typecheck": "pnpm -r typecheck && pnpx convex typecheck",
    "test": "pnpm --filter @jokko/web test",
    "test:e2e": "pnpm --filter @jokko/web test:e2e"
  },
  "dependencies": {
    "@auth/core": "^0.37.4",
    "@aws-sdk/client-ses": "^3.946.0",
    "@convex-dev/auth": "^0.0.90",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@jokko/core": "workspace:*",
    "@react-email/components": "^1.0.1",
    "@react-email/render": "^2.0.0",
    "@xmldom/xmldom": "^0.8.11",
    "convex": "^1.30.0",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "libphonenumber-js": "^1.12.41",
    "openai": "^6.10.0",
    "react": "19.2.0",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@types/react": "^19",
    "convex-test": "^0.0.41",
    "typescript": "^5",
    "vite": "^7.2.6",
    "vitest": "^4.0.15"
  },
  "packageManager": "pnpm@10.28.1"
}
